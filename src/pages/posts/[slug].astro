---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import ArticleBody from "../../components/ArticleBody.astro";
import SeriesNav from "../../components/SeriesNav.astro";
import CategoryBadge from "../../components/CategoryBadge.astro";
import ReadingTimeBadge from "../../components/ReadingTimeBadge.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import {
  getPublishedPosts,
  getSeriesNavigator,
  getRelatedPosts,
  getCategoryIndex,
  formatDate,
  formatDateShort,
  splitMemberContent,
  categoryAccent,
} from "../../lib/posts";
import { extractToc } from "../../lib/toc";

export async function getStaticPaths() {
  return getPublishedPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { prev, next } = getSeriesNavigator(post);
const related = getRelatedPosts(post, 3);
const categories = getCategoryIndex();
const description = post.seo_description || post.excerpt || `${post.category ?? "記事"} | ${post.title}`;
const { freeBlocks, hasMemberContent } = splitMemberContent(post.blocks);
const toc = extractToc(freeBlocks);
const hasToc = toc.length > 1;
const accent = categoryAccent(post.category);
const ogImage = post.cover ?? `/og/${post.slug}.png`;
const publishedTime = post.date ? new Date(post.date).toISOString() : undefined;
const canonicalUrl = new URL(`/posts/${post.slug}/`, Astro.site ?? "https://qryptraveller.com").toString();
const absoluteOgImage = new URL(ogImage, Astro.site ?? "https://qryptraveller.com").toString();
const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  ...(publishedTime && { datePublished: publishedTime }),
  image: [absoluteOgImage],
  author: { "@type": "Person", name: "Qryptraveller" },
  publisher: { "@type": "Organization", name: "Qryptraveller.com" },
  mainEntityOfPage: canonicalUrl,
};
---

<Layout
  title={post.title}
  description={description}
  ogImage={ogImage}
  ogImageAlt={`${post.title} のサムネイル`}
  ogType="article"
  publishedTime={publishedTime}
  articleSection={post.category ?? undefined}
  structuredData={structuredData}
>
  <div class="max-w-page mx-auto px-4 md:px-8 py-12 md:py-16 lg:grid lg:grid-cols-[minmax(0,1fr)_260px] lg:gap-12 lg:items-start">
    <div
      id="article-main"
      class="max-w-prose w-full mx-auto lg:mx-0"
      data-pagefind-body
      data-pagefind-filter={post.category ? `category:${post.category}` : undefined}
    >
      <!-- Breadcrumb -->
      <nav class="mb-6 flex flex-wrap items-center gap-2 text-xs text-ink-muted" data-pagefind-ignore>
        <a href="/" class="no-underline hover:text-ink">ホーム</a>
        <span class="text-wandering/60">〜</span>
        {post.category && (
          <>
            <a href={`/category/${encodeURIComponent(post.category)}/`} class="no-underline hover:text-ink">
              {post.category}
            </a>
            <span class="text-wandering/60">〜</span>
          </>
        )}
        {post.series && (
          <>
            <a href={`/series/${encodeURIComponent(post.series)}/`} class="no-underline hover:text-ink">
              {post.series}
            </a>
            {post.episode != null && <span class="font-mono">#{post.episode}</span>}
            {post.sub_episode && <span class="font-mono">({post.sub_episode})</span>}
          </>
        )}
      </nav>

      <!-- Header -->
      <header class="mb-10 pb-8 border-b border-paper-300">
        {post.category && (
          <div class="mb-4" data-pagefind-ignore>
            <CategoryBadge category={post.category} />
          </div>
        )}
        <h1 class="font-serif text-3xl md:text-4xl lg:text-5xl font-bold text-moss-dark leading-[1.3] mb-6">
          {post.title}
        </h1>
        <div class="flex flex-wrap items-center gap-3 text-sm text-ink-muted" data-pagefind-ignore>
          <time>{formatDate(post.date)}</time>
          {post.series && post.episode != null && (
            <>
              <span class="w-[3px] h-[3px] rounded-full bg-ink-muted/50" aria-hidden="true"></span>
              <span class="font-mono text-xs">{post.series} #{post.episode}</span>
            </>
          )}
          <span class="w-[3px] h-[3px] rounded-full bg-ink-muted/50" aria-hidden="true"></span>
          <ReadingTimeBadge minutes={post.reading_time} />
          {post.char_count > 0 && (
            <>
              <span class="w-[3px] h-[3px] rounded-full bg-ink-muted/50" aria-hidden="true"></span>
              <span class="text-xs">{post.char_count.toLocaleString()}字</span>
            </>
          )}
        </div>
      </header>

      {post.cover && (
        <figure class="mb-10 -mx-4 md:mx-0">
          <img src={post.cover} alt="" class="w-full rounded-md" loading="eager" />
        </figure>
      )}

      {hasToc && (
        <div data-pagefind-ignore>
          <TableOfContents entries={toc} variant="mobile" />
        </div>
      )}

      <ArticleBody blocks={freeBlocks} />

      {hasMemberContent && (
        <div id="member-gate" data-slug={post.slug} class="mt-6 border-t border-paper-300 pt-6 text-center">
          <p class="text-ink-muted mb-4">この続きは特別会員の「旅路の証人」限定です。</p>
          <a
            href={`/join?ref=${encodeURIComponent(`/posts/${post.slug}/`)}`}
            class="inline-block px-6 py-3 bg-moss-dark text-paper-100 rounded-md text-sm no-underline hover:bg-moss"
          >
            旅路の証人になって続きを読む
          </a>
        </div>
      )}

      {hasMemberContent && (
        <div id="member-content" class="hidden">
          <div id="member-content-skeleton" class="space-y-3 mt-6 animate-pulse" aria-hidden="true">
            <div class="h-4 bg-paper-300 rounded w-full"></div>
            <div class="h-4 bg-paper-300 rounded w-11/12"></div>
            <div class="h-4 bg-paper-300 rounded w-full"></div>
            <div class="h-4 bg-paper-300 rounded w-4/5"></div>
          </div>
          <div id="member-content-body" class="prose-article"></div>
        </div>
      )}

      <!-- Decorative end-of-article divider + stamp -->
      <div class="flex items-center gap-2.5 my-9" aria-hidden="true" data-pagefind-ignore>
        <div class="flex-1 border-t border-dashed border-paper-300"></div>
        <div class={`w-1.5 h-1.5 rounded-full bg-${accent}`}></div>
        <div class="flex-1 border-t border-dashed border-paper-300"></div>
      </div>
      <div class="flex justify-center mb-10" aria-hidden="true">
        <div class={`w-16 h-16 rounded-full border-2 border-dashed border-${accent} text-${accent} flex items-center justify-center -rotate-[8deg] font-mono text-[9px] font-bold tracking-wide text-center leading-tight`}>
          {post.category ?? "旅路"}<br />読了
        </div>
      </div>

      {post.tags.length > 0 && (
        <div class="mt-4 pt-6 border-t border-paper-300">
          <div class="text-xs uppercase tracking-widest text-ink-muted mb-3">タグ</div>
          <div class="flex flex-wrap gap-2">
            {post.tags.map((tag) => (
              <a href={`/tag/${encodeURIComponent(tag)}/`} class="tag-pill">
                {tag}
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="print-footer hidden">{canonicalUrl}</div>
    </div>

    <!-- Sidebar -->
    <aside id="article-side" class="mt-10 lg:mt-0 flex flex-col gap-6 lg:sticky lg:top-24">
      {hasToc && (
        <div class="bg-paper-50 border border-paper-200 rounded-lg p-4">
          <TableOfContents entries={toc} variant="desktop" />
        </div>
      )}

      <div class="bg-paper-50 border border-paper-200 rounded-lg p-4">
        <div class="text-xs uppercase tracking-widest text-ink-muted mb-3">カテゴリ</div>
        <div class="flex flex-col gap-2 text-sm">
          {categories.map((c) => (
            <a
              href={`/category/${encodeURIComponent(c.name)}/`}
              class="flex justify-between no-underline text-ink hover:text-moss-dark"
            >
              <span>{c.name}</span>
              <span class="text-ink-muted text-xs">{c.count}</span>
            </a>
          ))}
        </div>
      </div>

      {related.length > 0 && (
        <div class="bg-paper-50 border border-paper-200 rounded-lg p-4">
          <div class="text-xs uppercase tracking-widest text-ink-muted mb-3">関連記事</div>
          <div class="flex flex-col gap-3">
            {related.map((p) => {
              const relAccent = categoryAccent(p.category);
              return (
                <a href={`/posts/${p.slug}/`} class="flex gap-2.5 no-underline text-inherit group">
                  {p.cover ? (
                    <img
                      src={p.cover}
                      alt=""
                      loading="lazy"
                      class="img-shimmer w-16 aspect-video rounded object-cover flex-shrink-0"
                      onload="this.classList.add('is-loaded')"
                    />
                  ) : (
                    <div class={`w-16 aspect-video rounded flex-shrink-0 bg-gradient-to-br from-${relAccent}/25 to-${relAccent}/5`}></div>
                  )}
                  <div>
                    <div class="text-[11px] font-mono text-ink-muted mb-0.5">{formatDateShort(p.date)}</div>
                    <div class="text-xs leading-snug group-hover:text-moss-dark">{p.title}</div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>
      )}

      <div class="bg-paper-50 border border-paper-200 rounded-lg p-4">
        <div class="text-xs uppercase tracking-widest text-ink-muted mb-3">著者</div>
        <a href="/about/" class="flex items-center gap-3 no-underline">
          <div class="w-11 h-11 rounded-full bg-gradient-to-br from-wandering/30 to-earth/15 flex-shrink-0"></div>
          <div>
            <div class="text-sm font-semibold text-ink">Qryptraveller</div>
            <div class="text-xs text-ink-muted">放浪記の記録者</div>
          </div>
        </a>
      </div>
    </aside>
  </div>

  {post.series && (
    <div class="max-w-page mx-auto px-4 md:px-8">
      <div class="max-w-prose w-full mx-auto lg:mx-0">
        <SeriesNav series={post.series} prev={prev} next={next} />
      </div>
    </div>
  )}
</Layout>

<script>
  function fitSticky() {
    const main = document.getElementById("article-main");
    const side = document.getElementById("article-side");
    if (!main || !side) return;
    if (main.offsetHeight < side.offsetHeight) {
      side.style.position = "static";
    }
  }
  window.addEventListener("load", fitSticky);
</script>

{hasMemberContent && (
  <script>
    import { createSupabaseBrowserClient } from "../../lib/supabase/browser";

    const gate = document.getElementById("member-gate");
    const content = document.getElementById("member-content");
    const skeleton = document.getElementById("member-content-skeleton");
    const body = document.getElementById("member-content-body");
    const slug = gate?.dataset.slug;

    if (slug) {
      const supabase = createSupabaseBrowserClient();
      supabase.auth.getSession().then(async ({ data: { session } }) => {
        if (!session) return;

        gate?.classList.add("hidden");
        content?.classList.remove("hidden");

        const res = await fetch(`/api/posts/${encodeURIComponent(slug)}/member-content.json`);
        if (!res.ok) {
          content?.classList.add("hidden");
          gate?.classList.remove("hidden");
          return;
        }

        const { html } = await res.json();
        if (body) body.innerHTML = html;
        skeleton?.remove();
        gate?.remove();
      });
    }
  </script>
)}
