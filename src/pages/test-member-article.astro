---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { createSupabaseServerClient } from "../lib/supabase/server";
import { isMember as checkIsMember } from "../lib/members";

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

const {
  data: { user },
} = await supabase.auth.getUser();

const isMember = user ? await checkIsMember(supabase, user.id) : false;
---

<Layout
  title="【テスト記事】旅路の証人 動作確認"
  description="会員限定コンテンツ機能の動作確認用ダミー記事です。"
  noIndex
>
  <article class="max-w-prose mx-auto px-4 md:px-0 py-16">
    <header class="mb-8">
      <div class="text-xs uppercase tracking-[0.3em] text-earth mb-3">Test</div>
      <h1 class="font-serif text-3xl font-semibold text-ink">
        【テスト記事】旅路の証人 会員限定コンテンツ動作確認
      </h1>
      <p class="text-sm text-ink-muted mt-2">
        これは「旅路の証人」機能の動作確認用ダミー記事です。実際の記事本文ではありません。
      </p>
    </header>

    <div class="leading-loose text-ink space-y-4">
      <p>(ここは無料公開部分のダミーテキストです。誰でも読めます。実際の記事ではここに導入部分が入ります。)</p>
      <p>ここまでは誰でも読めますが、この続きは「旅路の証人」だけが読める設定になっています。</p>
    </div>

    {
      isMember ? (
        <div class="leading-loose text-ink space-y-4 mt-6 border-t border-paper-300 pt-6">
          <p class="text-sm text-moss mb-2">✓ 会員限定コンテンツが表示されています(ログイン中: {user?.email})</p>
          <p>(ここは会員限定部分のダミーテキストです。ログインして「旅路の証人」になった人だけがこの文章を読めています。)</p>
          <p>
            ここまで表示されていれば、OAuthログイン〜membersテーブル登録〜コンテンツ出し分けの一連の流れが正しく動作しています。
          </p>
          <p class="pt-2">
            <a href="/api/auth/logout" class="text-sm text-earth hover:text-ink underline">
              ログアウトする(別プロバイダーでのテスト用)
            </a>
          </p>
        </div>
      ) : (
        <div class="mt-6 border-t border-paper-300 pt-6 text-center">
          <p class="text-ink-muted mb-4">この続きは特別会員の「旅路の証人」限定です。</p>
          <a
            href={`/join?ref=${encodeURIComponent("/test-member-article")}`}
            class="inline-block px-6 py-3 bg-moss-light text-paper-100 rounded-md text-sm no-underline hover:bg-moss"
          >
            旅路の証人になって続きを読む
          </a>
        </div>
      )
    }
  </article>
</Layout>
