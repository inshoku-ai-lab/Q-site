---
import Layout from "../../layouts/Layout.astro";
import { getCategoryIndex } from "../../lib/posts";

const cats = getCategoryIndex().sort((a, b) => b.count - a.count);

const catDesc: Record<string, string> = {
  "放浪記": "20年以上の世界放浪を綴った自伝的連載。",
  "思想・理論": "デボリューション理論、意識論、覚醒について。",
  "時事・情報戦": "メディアが報じない情報戦争・選挙・ビットコインの真実。",
  "エッセイ・その他": "単発の随筆・観察・雑記。",
};

const catAccent: Record<string, string> = {
  "放浪記": "wandering",
  "思想・理論": "thought",
  "時事・情報戦": "current",
  "エッセイ・その他": "essay",
};
---

<Layout title="カテゴリ一覧">
  <div class="max-w-page mx-auto px-4 md:px-8 py-16">
    <header class="mb-12">
      <div class="text-xs uppercase tracking-[0.3em] text-earth mb-3">Categories</div>
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-moss-dark">カテゴリで読む</h1>
    </header>

    <div class="grid sm:grid-cols-2 gap-5">
      {cats.map((c) => {
        const accent = catAccent[c.name] ?? "moss";
        return (
          <a
            href={`/category/${encodeURIComponent(c.name)}/`}
            class={`block p-6 rounded-lg bg-paper-50 border border-paper-200 no-underline card-hover border-l-4 border-l-${accent}`}
          >
            <div class={`text-[10px] uppercase tracking-widest text-${accent} mb-2`}>Category</div>
            <h2 class="font-serif text-2xl font-semibold text-moss-dark mb-2">{c.name}</h2>
            <p class="text-sm text-ink-muted mb-3">{catDesc[c.name]}</p>
            <div class="text-xs text-ink-muted font-mono">{c.count}本の記事</div>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
