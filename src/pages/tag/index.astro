---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import { getTagIndex } from "../../lib/posts";

const tags = getTagIndex();
const maxCount = Math.max(...tags.map((t) => t.count), 1);
---

<Layout title="タグ一覧">
  <div class="max-w-page mx-auto px-4 md:px-8 py-16">
    <header class="mb-12">
      <div class="text-xs uppercase tracking-[0.3em] text-earth mb-3">All Tags</div>
      <h1 class="font-serif text-3xl md:text-4xl font-semibold text-moss-dark">タグで読む</h1>
      <p class="mt-3 text-ink-muted">{tags.length}個のテーマタグ。</p>
    </header>

    <div class="flex flex-wrap gap-3">
      {tags.map((t) => {
        const scale = 0.85 + 0.5 * (t.count / maxCount);
        return (
          <a
            href={`/tag/${encodeURIComponent(t.name)}/`}
            class="inline-flex items-baseline gap-1.5 px-3 py-1.5 rounded-full bg-paper-50 border border-paper-300 text-ink-light no-underline hover:bg-moss/10 hover:border-moss hover:text-moss-dark"
            style={`font-size: ${scale}rem;`}
          >
            <span>{t.name}</span>
            <span class="text-xs text-ink-muted font-mono">{t.count}</span>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
