---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
import { requireAdmin, logAdminAccess } from "../../lib/admin";
import { buildDashboardStats, type MemberRow, type ArchiveRow } from "../../lib/adminStats";

const auth = await requireAdmin(Astro.request, Astro.cookies);
if (!auth.ok) {
  return Astro.redirect("/");
}
await logAdminAccess(auth.admin, auth.email, "view_dashboard");

const { data: membersData } = await auth.admin
  .from("members")
  .select("id, email, display_name, provider, agreement_reason, joined_at, referrer_article_slug, first_read_article_slug, admin_note")
  .order("joined_at", { ascending: false });
const { data: archiveData } = await auth.admin
  .from("member_stats_archive")
  .select("provider, agreement_reason, joined_at, left_at");

const members = (membersData ?? []) as MemberRow[];
const archive = (archiveData ?? []) as ArchiveRow[];
const stats = buildDashboardStats(members, archive);

const DOW_LABELS = ["日", "月", "火", "水", "木", "金", "土"];
const maxHeatmapValue = Math.max(1, ...stats.heatmap.flat());
const maxTimeSeriesValue = Math.max(1, ...stats.timeSeries.map((t) => Math.max(t.joins, t.leaves)));
---

<Layout title="管理ダッシュボード" description="旅路の証人 管理ダッシュボード" noIndex>
  <div class="max-w-5xl mx-auto px-4 md:px-0 py-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="font-serif text-2xl font-semibold text-ink">管理ダッシュボード</h1>
      <nav class="text-sm">
        <a href="/admin/members" class="text-earth hover:text-ink underline">会員一覧へ</a>
      </nav>
    </div>

    {stats.recentlyPassedMilestone && (
      <div class="mb-8 p-4 rounded-md bg-moss/10 border border-moss text-ink text-sm">
        🎉 「旅路の証人」が {stats.recentlyPassedMilestone}人 に到達しました！
      </div>
    )}

    <!-- Top stats -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-12">
      <div class="border border-paper-300 rounded-md p-4">
        <div class="text-xs text-ink-muted mb-1">現在の会員数</div>
        <div class="text-2xl font-semibold text-ink">{stats.currentCount}</div>
      </div>
      <div class="border border-paper-300 rounded-md p-4">
        <div class="text-xs text-ink-muted mb-1">累計入会者数</div>
        <div class="text-2xl font-semibold text-ink">{stats.cumulativeJoins}</div>
      </div>
      <div class="border border-paper-300 rounded-md p-4">
        <div class="text-xs text-ink-muted mb-1">退会者数</div>
        <div class="text-2xl font-semibold text-ink">{stats.churnCount}</div>
      </div>
      {stats.nextMilestone && (
        <div class="border border-paper-300 rounded-md p-4 col-span-2 md:col-span-3">
          <div class="text-xs text-ink-muted">次の節目まであと {stats.nextMilestone - stats.currentCount}人 ({stats.nextMilestone}人)</div>
        </div>
      )}
    </div>

    <!-- Time series -->
    <section class="mb-12">
      <h2 class="font-serif text-lg font-semibold text-ink mb-4">入会・退会の推移(月別)</h2>
      {stats.timeSeries.length === 0 ? (
        <p class="text-sm text-ink-muted">データがありません。</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="text-sm w-full border-collapse">
            <thead>
              <tr class="border-b border-paper-300 text-left text-ink-muted">
                <th class="py-2 pr-4">月</th>
                <th class="py-2 pr-4">入会</th>
                <th class="py-2 pr-4">退会</th>
                <th class="py-2">推移</th>
              </tr>
            </thead>
            <tbody>
              {stats.timeSeries.map((t) => (
                <tr class="border-b border-paper-200">
                  <td class="py-2 pr-4 font-mono text-xs">{t.month}</td>
                  <td class="py-2 pr-4">{t.joins}</td>
                  <td class="py-2 pr-4">{t.leaves}</td>
                  <td class="py-2">
                    <div class="flex gap-1 items-center h-4">
                      <div class="bg-moss h-full" style={`width: ${(t.joins / maxTimeSeriesValue) * 100}px`} />
                      <div class="bg-rust h-full" style={`width: ${(t.leaves / maxTimeSeriesValue) * 100}px`} />
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- Provider / reason breakdown -->
    <div class="grid md:grid-cols-2 gap-8 mb-12">
      <section>
        <h2 class="font-serif text-lg font-semibold text-ink mb-4">プロバイダー別内訳</h2>
        <ul class="space-y-2 text-sm">
          {stats.providerBreakdown.map((p) => (
            <li class="flex justify-between border-b border-paper-200 py-1.5">
              <span>{p.label}</span>
              <span class="text-ink-muted">{p.count}人</span>
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2 class="font-serif text-lg font-semibold text-ink mb-4">理由別内訳・継続率</h2>
        <ul class="space-y-2 text-sm">
          {stats.reasonBreakdown.map((r) => (
            <li class="flex justify-between border-b border-paper-200 py-1.5">
              <span>{r.label}</span>
              <span class="text-ink-muted">{r.total}人(継続率 {r.retentionRate}%)</span>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <!-- Cohort retention -->
    <section class="mb-12">
      <h2 class="font-serif text-lg font-semibold text-ink mb-4">コホート分析(入会月別 継続率)</h2>
      {stats.cohorts.length === 0 ? (
        <p class="text-sm text-ink-muted">データがありません。</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="text-sm w-full border-collapse">
            <thead>
              <tr class="border-b border-paper-300 text-left text-ink-muted">
                <th class="py-2 pr-4">入会月</th>
                <th class="py-2 pr-4">人数</th>
                <th class="py-2 pr-4">1ヶ月後</th>
                <th class="py-2 pr-4">3ヶ月後</th>
                <th class="py-2 pr-4">半年後</th>
              </tr>
            </thead>
            <tbody>
              {stats.cohorts.map((c) => (
                <tr class="border-b border-paper-200">
                  <td class="py-2 pr-4 font-mono text-xs">{c.month}</td>
                  <td class="py-2 pr-4">{c.total}</td>
                  <td class="py-2 pr-4">{c.retention1mo === null ? "―" : `${c.retention1mo}%`}</td>
                  <td class="py-2 pr-4">{c.retention3mo === null ? "―" : `${c.retention3mo}%`}</td>
                  <td class="py-2 pr-4">{c.retention6mo === null ? "―" : `${c.retention6mo}%`}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <!-- Heatmap -->
    <section class="mb-12">
      <h2 class="font-serif text-lg font-semibold text-ink mb-4">入会の曜日・時間帯ヒートマップ</h2>
      <div class="overflow-x-auto">
        <table class="text-xs border-collapse">
          <thead>
            <tr>
              <th></th>
              {Array.from({ length: 24 }, (_, h) => <th class="px-1 py-1 font-normal text-ink-muted">{h}</th>)}
            </tr>
          </thead>
          <tbody>
            {stats.heatmap.map((row, dow) => (
              <tr>
                <th class="pr-2 text-ink-muted font-normal text-left">{DOW_LABELS[dow]}</th>
                {row.map((v) => (
                  <td class="p-0.5">
                    <div
                      class="w-4 h-4 rounded-sm"
                      style={`background-color: rgba(109, 142, 93, ${v === 0 ? 0.05 : v / maxHeatmapValue})`}
                      title={`${v}件`}
                    />
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Referral tracking -->
    <section class="mb-12">
      <h2 class="font-serif text-lg font-semibold text-ink mb-4">流入経路(現会員のみ)</h2>
      {stats.topReferrers.length === 0 ? (
        <p class="text-sm text-ink-muted">データがありません。</p>
      ) : (
        <ul class="space-y-2 text-sm">
          {stats.topReferrers.map((r) => (
            <li class="flex justify-between border-b border-paper-200 py-1.5">
              <a href={`/posts/${r.slug}/`} class="text-earth hover:text-ink underline break-all">{r.slug}</a>
              <span class="text-ink-muted whitespace-nowrap ml-4">{r.count}人</span>
            </li>
          ))}
        </ul>
      )}
    </section>
  </div>
</Layout>
