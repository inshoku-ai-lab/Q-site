---
export const prerender = false;
import Layout from "../../../layouts/Layout.astro";
import { requireAdmin, logAdminAccess } from "../../../lib/admin";
import { formatDate } from "../../../lib/posts";

const auth = await requireAdmin(Astro.request, Astro.cookies);
if (!auth.ok) {
  return Astro.redirect("/");
}
await logAdminAccess(auth.admin, auth.email, "view_members");

const url = new URL(Astro.request.url);
const providerFilter = url.searchParams.get("provider") ?? "";
const reasonFilter = url.searchParams.get("reason") ?? "";
const fromFilter = url.searchParams.get("from") ?? "";
const toFilter = url.searchParams.get("to") ?? "";
const q = url.searchParams.get("q") ?? "";

let query = auth.admin
  .from("members")
  .select("id, email, display_name, provider, agreement_reason, joined_at")
  .order("joined_at", { ascending: false });

if (providerFilter) query = query.eq("provider", providerFilter);
if (reasonFilter) query = query.eq("agreement_reason", reasonFilter);
if (fromFilter) query = query.gte("joined_at", fromFilter);
if (toFilter) query = query.lte("joined_at", toFilter);

const { data } = await query;
let members = data ?? [];
if (q) {
  const needle = q.toLowerCase();
  members = members.filter(
    (m) => m.email?.toLowerCase().includes(needle) || m.display_name?.toLowerCase().includes(needle)
  );
}

const PROVIDER_LABELS: Record<string, string> = { google: "Google", facebook: "Facebook", line: "LINE" };
const REASON_LABELS: Record<string, string> = {
  financial: "金銭的利益",
  referral: "推薦",
  other: "その他応援",
};

const csvParams = new URLSearchParams(url.search);
---

<Layout title="会員一覧" description="旅路の証人 会員一覧" noIndex>
  <div class="max-w-5xl mx-auto px-4 md:px-0 py-12">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-serif text-2xl font-semibold text-moss-dark">会員一覧({members.length}人)</h1>
      <nav class="text-sm flex gap-4">
        <a href="/admin" class="text-earth hover:text-ink underline">ダッシュボードへ</a>
        <a href={`/api/admin/members.csv?${csvParams.toString()}`} class="text-earth hover:text-ink underline">CSVエクスポート</a>
      </nav>
    </div>

    <form method="get" class="flex flex-wrap gap-3 mb-6 text-sm">
      <input type="text" name="q" value={q} placeholder="メール・名前で検索" class="border border-paper-300 rounded px-3 py-1.5" />
      <select name="provider" class="border border-paper-300 rounded px-3 py-1.5">
        <option value="">プロバイダー(すべて)</option>
        <option value="google" selected={providerFilter === "google"}>Google</option>
        <option value="facebook" selected={providerFilter === "facebook"}>Facebook</option>
        <option value="line" selected={providerFilter === "line"}>LINE</option>
      </select>
      <select name="reason" class="border border-paper-300 rounded px-3 py-1.5">
        <option value="">理由(すべて)</option>
        <option value="financial" selected={reasonFilter === "financial"}>金銭的利益</option>
        <option value="referral" selected={reasonFilter === "referral"}>推薦</option>
        <option value="other" selected={reasonFilter === "other"}>その他応援</option>
      </select>
      <input type="date" name="from" value={fromFilter} class="border border-paper-300 rounded px-3 py-1.5" />
      <input type="date" name="to" value={toFilter} class="border border-paper-300 rounded px-3 py-1.5" />
      <button type="submit" class="px-4 py-1.5 bg-moss-dark text-paper-100 rounded">絞り込む</button>
      <a href="/admin/members" class="px-4 py-1.5 border border-paper-300 rounded text-ink-muted">リセット</a>
    </form>

    <div class="overflow-x-auto">
      <table class="text-sm w-full border-collapse">
        <thead>
          <tr class="border-b border-paper-300 text-left text-ink-muted">
            <th class="py-2 pr-4">名前</th>
            <th class="py-2 pr-4">メール</th>
            <th class="py-2 pr-4">プロバイダー</th>
            <th class="py-2 pr-4">理由</th>
            <th class="py-2 pr-4">登録日</th>
          </tr>
        </thead>
        <tbody>
          {members.map((m) => (
            <tr class="border-b border-paper-200 hover:bg-paper-50">
              <td class="py-2 pr-4">
                <a href={`/admin/members/${m.id}`} class="text-earth hover:text-ink underline">
                  {m.display_name || "(名前なし)"}
                </a>
              </td>
              <td class="py-2 pr-4">{m.email}</td>
              <td class="py-2 pr-4">{PROVIDER_LABELS[m.provider] ?? m.provider}</td>
              <td class="py-2 pr-4">{REASON_LABELS[m.agreement_reason] ?? m.agreement_reason}</td>
              <td class="py-2 pr-4 font-mono text-xs">{formatDate(m.joined_at)}</td>
            </tr>
          ))}
        </tbody>
      </table>
      {members.length === 0 && <p class="text-sm text-ink-muted py-8 text-center">該当する会員がいません。</p>}
    </div>
  </div>
</Layout>
