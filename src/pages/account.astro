---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import { createSupabaseServerClient } from "../lib/supabase/server";
import { formatDate, formatDateShort, getMemberOnlyPosts, categoryAccentHex } from "../lib/posts";

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);

const {
  data: { user },
} = await supabase.auth.getUser();

let member: { provider: string; joined_at: string } | null = null;
if (user) {
  const { data } = await supabase
    .from("members")
    .select("provider, joined_at")
    .eq("auth_user_id", user.id)
    .maybeSingle();
  member = data;
}

const memberPosts = user && member ? getMemberOnlyPosts(6) : [];

const PROVIDER_LABELS: Record<string, string> = {
  google: "Google",
  facebook: "Facebook",
  line: "LINE",
};
---

<Layout title="アカウント設定" description="旅路の証人アカウントの設定ページです。" noIndex>
  <div class="max-w-prose mx-auto px-4 md:px-0 py-16">
    {!user && (
      <div class="text-center py-12">
        <h1 class="font-serif text-2xl font-semibold text-moss-dark mb-4">アカウント設定</h1>
        <p class="text-ink-muted mb-4">ログインしていません。</p>
        <a href="/join" class="text-earth hover:text-ink underline">「旅路の証人」になる</a>
      </div>
    )}

    {user && !member && (
      <p class="text-ink-muted">会員情報が見つかりませんでした。</p>
    )}

    {user && member && (
      <>
        <header class="flex items-center gap-5 mb-10 pb-7 border-b border-paper-300">
          <div class="w-[60px] h-[60px] rounded-full bg-gradient-to-br from-wandering/30 to-earth/15 flex-shrink-0"></div>
          <div>
            <h1 class="font-serif text-xl font-semibold text-ink mb-2">おかえりなさい、旅人さん</h1>
            <span class="inline-flex items-center gap-1.5 text-xs px-3 py-1 rounded-full bg-earth/10 text-earth font-medium">
              🧭 旅路の証人
            </span>
          </div>
        </header>

        {memberPosts.length > 0 && (
          <div class="mb-9">
            <h2 class="font-serif text-base text-moss-dark mb-4">会員限定記事</h2>
            <div class="flex flex-col">
              {memberPosts.map((p) => {
                const hex = categoryAccentHex(p.category);
                return (
                  <a href={`/posts/${p.slug}/`} class="flex gap-3.5 items-center py-3.5 border-b border-paper-300 last:border-0 no-underline text-inherit group">
                    {p.cover ? (
                      <img src={p.cover} alt="" loading="lazy" class="w-20 aspect-video rounded object-cover flex-shrink-0" />
                    ) : (
                      <div class="w-20 aspect-video rounded flex-shrink-0" style={`background:linear-gradient(135deg, ${hex}38, ${hex}0d)`} />
                    )}
                    <div>
                      <div class="text-[10.5px] mb-0.5" style={`color:${hex}`}>{p.category}</div>
                      <div class="font-serif text-sm text-ink group-hover:text-moss-dark leading-snug">{p.title}</div>
                      <div class="text-[11px] text-ink-muted font-mono mt-0.5">{formatDateShort(p.date)}</div>
                    </div>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <div class="mb-9">
          <h2 class="font-serif text-base text-moss-dark mb-4">アカウント</h2>
          <div class="flex flex-col">
            <div class="flex justify-between py-3.5 border-b border-paper-300 text-sm">
              <span class="text-ink">メールアドレス</span>
              <span class="text-ink-muted">{user.email}</span>
            </div>
            <div class="flex justify-between py-3.5 border-b border-paper-300 text-sm">
              <span class="text-ink">ログイン方法</span>
              <span class="text-ink-muted">{PROVIDER_LABELS[member.provider] ?? member.provider}</span>
            </div>
            <div class="flex justify-between py-3.5 border-b border-paper-300 text-sm">
              <span class="text-ink">「旅路の証人」になった日</span>
              <span class="text-ink-muted">{formatDate(member.joined_at)}</span>
            </div>
            <a href="/api/auth/logout" class="flex justify-between py-3.5 border-b border-paper-300 text-sm no-underline text-ink hover:text-moss-dark">
              <span>ログアウト</span>
              <span class="text-ink-muted">→</span>
            </a>
          </div>
        </div>

        <div class="border-t border-paper-300 pt-8">
          <h2 class="font-serif text-base font-semibold text-moss-dark mb-3">退会する</h2>
          <p class="text-sm text-ink-muted mb-4">
            退会すると、アカウントと会員情報は即座に完全に削除されます。この操作は元に戻せません。
          </p>
          <button
            id="delete-account-btn"
            type="button"
            class="px-5 py-2.5 border border-rust text-rust rounded-md text-sm hover:bg-rust hover:text-paper-100"
          >
            退会する
          </button>
          <p id="delete-error" class="text-sm text-rust mt-4 hidden"></p>
        </div>
      </>
    )}
  </div>
</Layout>

{user && member && (
  <script>
    const btn = document.getElementById("delete-account-btn");
    const errorEl = document.getElementById("delete-error");

    btn?.addEventListener("click", async () => {
      const confirmed = window.confirm("本当に退会しますか？この操作は元に戻せません。");
      if (!confirmed) return;

      btn.setAttribute("disabled", "true");
      const res = await fetch("/api/account/delete", { method: "POST" });

      if (res.ok) {
        window.location.href = "/";
        return;
      }

      btn.removeAttribute("disabled");
      if (errorEl) {
        errorEl.textContent = "退会処理に失敗しました。時間を置いて再度お試しください。";
        errorEl.classList.remove("hidden");
      }
    });
  </script>
)}
