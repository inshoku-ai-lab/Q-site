---
const pathname = Astro.url.pathname;
const isActive = (p: string) => (p === "/" ? pathname === "/" : pathname.startsWith(p));

const nav = [
  { href: "/", label: "ホーム" },
  { href: "/series/", label: "シリーズ" },
  { href: "/category/", label: "カテゴリ" },
  { href: "/archive/", label: "アーカイブ" },
  { href: "/about/", label: "About" },
];
---

<header class="border-b border-paper-300 bg-paper-100/90 backdrop-blur sticky top-0 z-20">
  <div class="max-w-page mx-auto px-4 md:px-8 py-4 flex items-center justify-between gap-6">
    <a href="/" class="no-underline flex flex-col leading-none">
      <span class="font-serif font-semibold text-lg md:text-xl text-moss-dark tracking-wide">
        Qryptraveller's Notes
      </span>
      <span class="text-[10px] uppercase tracking-widest text-ink-muted mt-0.5">
        Records of a Roaming Mind
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-sm">
      {
        nav.map((n) => (
          <a
            href={n.href}
            class={`no-underline transition-colors ${
              isActive(n.href)
                ? "text-moss-dark font-medium"
                : "text-ink-muted hover:text-ink"
            }`}
          >
            {n.label}
          </a>
        ))
      }
    </nav>

    <!-- Mobile menu toggle -->
    <button
      id="menu-toggle"
      class="md:hidden p-2 text-ink-muted"
      aria-label="メニュー"
    >
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <nav id="mobile-menu" class="hidden md:hidden border-t border-paper-300 bg-paper-100">
    <div class="max-w-page mx-auto px-4 py-2 flex flex-col">
      {
        nav.map((n) => (
          <a
            href={n.href}
            class={`no-underline py-3 border-b border-paper-200 last:border-0 transition-colors ${
              isActive(n.href) ? "text-moss-dark font-medium" : "text-ink-muted"
            }`}
          >
            {n.label}
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  toggle?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
