---
interface Props {
  name: string;
  count: number;
  description?: string;
  cover?: string | null;
  accent?: string;
}

const { name, count, description } = Astro.props;
const href = `/series/${encodeURIComponent(name)}/`;
---

<a href={href} class="block group no-underline card-hover bg-paper-50 rounded-lg p-[18px] border border-paper-200 h-full flex flex-col">
  <span class="inline-flex self-start text-[10px] uppercase tracking-wider font-medium px-2.5 py-1 rounded-full bg-earth text-paper-100 mb-2.5">
    Series
  </span>
  <h3 class="font-serif text-base font-semibold text-ink leading-tight mb-1.5 group-hover:text-moss-dark">
    {name}
  </h3>
  {description && <p class="text-[13px] text-ink-muted leading-snug line-clamp-2 mb-2.5 flex-1">{description}</p>}
  <div class="text-xs text-ink-muted">全 {count} 話</div>
</a>
