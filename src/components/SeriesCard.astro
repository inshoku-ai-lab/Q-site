---
interface Props {
  name: string;
  count: number;
  description?: string;
  cover?: string | null;
  accent?: string;
}

const { name, count, description, cover, accent = "moss" } = Astro.props;
const href = `/series/${encodeURIComponent(name)}/`;
---

<a href={href} class="block group no-underline card-hover bg-paper-50 rounded-lg overflow-hidden border border-paper-200 h-full flex flex-col">
  {cover ? (
    <div class="aspect-[4/3] overflow-hidden bg-paper-200">
      <img src={cover} alt="" loading="lazy" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" />
    </div>
  ) : (
    <div class={`aspect-[4/3] bg-gradient-to-br from-paper-200 to-${accent}/20 flex items-center justify-center`}>
      <span class={`font-serif text-3xl text-${accent}-dark/40`}>{name.charAt(0)}</span>
    </div>
  )}
  <div class="p-5 flex-1 flex flex-col">
    <div class="text-[10px] uppercase tracking-widest text-ink-muted mb-2">Series</div>
    <h3 class="font-serif text-xl font-semibold text-moss-dark leading-tight mb-2 group-hover:text-ink">
      {name}
    </h3>
    {description && <p class="text-sm text-ink-muted line-clamp-2 mb-3 flex-1">{description}</p>}
    <div class="text-xs text-ink-muted font-mono mt-auto">全 {count} 話</div>
  </div>
</a>
