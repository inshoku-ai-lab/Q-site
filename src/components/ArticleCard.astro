---
import type { Post } from "../lib/posts";
import { formatDateShort, categoryAccent, categoryAccentHex } from "../lib/posts";
import ReadingTimeBadge from "./ReadingTimeBadge.astro";

interface Props {
  post: Post;
  variant?: "default" | "compact" | "wide" | "related" | "scroll";
  showCategory?: boolean;
  headingLevel?: "h2" | "h3";
}

const { post, variant = "default", showCategory = true, headingLevel = "h3" } = Astro.props;
const accent = categoryAccent(post.category);
const accentHex = categoryAccentHex(post.category);
const href = `/posts/${post.slug}/`;
const Title = headingLevel;
---

{variant === "compact" ? (
  <a href={href} class="block py-4 border-b border-paper-200 last:border-0 no-underline group">
    <div class="flex items-baseline gap-3 mb-1.5">
      <time class="text-xs text-ink-muted font-mono">{formatDateShort(post.date)}</time>
      {showCategory && post.category && (
        <span class={`text-[10px] uppercase tracking-widest text-${accent}`}>
          {post.category}
        </span>
      )}
      {post.series && post.episode != null && (
        <span class="text-[10px] tracking-wider text-ink-muted">
          {post.series} #{post.episode}
        </span>
      )}
    </div>
    <Title class="font-serif text-base md:text-lg text-ink leading-snug group-hover:text-moss-dark transition-colors">
      {post.title}
    </Title>
  </a>
) : variant === "related" ? (
  <a href={href} class="block group no-underline card-hover bg-paper-50 rounded-lg overflow-hidden border border-paper-200 h-full flex flex-col">
    {post.cover ? (
      <div class="aspect-[16/9] overflow-hidden bg-paper-200">
        <img
          src={post.cover}
          alt=""
          loading="lazy"
          class="img-shimmer w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          onload="this.classList.add('is-loaded')"
        />
      </div>
    ) : (
      <div class={`aspect-[16/9] bg-gradient-to-br from-${accent}/20 to-${accent}/5 flex items-center justify-center`}>
        {post.category && (
          <span class={`text-xs uppercase tracking-widest text-${accent}/70 font-medium`}>
            {post.category}
          </span>
        )}
      </div>
    )}
    <div class="p-4 flex-1 flex flex-col">
      <div class="flex items-baseline gap-2 mb-2 flex-wrap">
        <time class="text-xs text-ink-muted font-mono">{formatDateShort(post.date)}</time>
        {post.series && post.episode != null && (
          <span class="text-[10px] tracking-wider text-ink-muted">{post.series} #{post.episode}</span>
        )}
      </div>
      <Title class="font-serif text-base leading-snug text-ink group-hover:text-moss-dark transition-colors mb-2 flex-1">
        {post.title}
      </Title>
      <ReadingTimeBadge minutes={post.reading_time} size="sm" />
    </div>
  </a>
) : variant === "wide" ? (
  <a href={href} class="block group no-underline card-hover bg-paper-50 rounded-lg overflow-hidden border border-paper-200">
    {post.cover && (
      <div class="aspect-[16/9] overflow-hidden bg-paper-200">
        <img
          src={post.cover}
          alt=""
          loading="lazy"
          class="img-shimmer w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          onload="this.classList.add('is-loaded')"
        />
      </div>
    )}
    <div class="p-3.5">
      <div class="flex items-baseline gap-3 mb-3">
        <time class="text-xs text-ink-muted font-mono">{formatDateShort(post.date)}</time>
        {showCategory && post.category && (
          <span class={`text-[11px] uppercase tracking-widest text-${accent} font-bold`}>
            {post.category}
          </span>
        )}
      </div>
      <Title class="font-serif text-lg leading-snug text-ink mb-2 min-h-[2.7em] group-hover:text-moss-dark">
        {post.title}
      </Title>
      <div class="text-xs text-ink-muted">
        {formatDateShort(post.date)} · 約{post.reading_time}分で読了
      </div>
    </div>
  </a>
) : variant === "scroll" ? (
  <a href={href} class="flex-none w-[200px] snap-start block group no-underline card-hover bg-paper-50 rounded-lg overflow-hidden border border-paper-200">
    {post.cover ? (
      <div class="aspect-[16/9] overflow-hidden bg-paper-200">
        <img
          src={post.cover}
          alt=""
          loading="lazy"
          class="img-shimmer w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          onload="this.classList.add('is-loaded')"
        />
      </div>
    ) : (
      <div
        class="aspect-[16/9] flex items-center justify-center"
        style={`background:linear-gradient(135deg, ${accentHex}38, ${accentHex}0d)`}
      >
        {post.category && (
          <span class="text-[11px] uppercase tracking-widest font-medium" style={`color:${accentHex}`}>
            {post.category}
          </span>
        )}
      </div>
    )}
    <div class="p-3">
      <div class="text-[11px] text-ink-muted mb-1.5">{formatDateShort(post.date)}</div>
      <Title class="font-serif text-[13.5px] leading-snug text-ink group-hover:text-moss-dark transition-colors line-clamp-2">
        {post.title}
      </Title>
    </div>
  </a>
) : (
  <a href={href} class="block group no-underline card-hover bg-paper-50 rounded-lg overflow-hidden border border-paper-200 h-full flex flex-col">
    {post.cover ? (
      <div class="aspect-[16/9] overflow-hidden bg-paper-200">
        <img
          src={post.cover}
          alt=""
          loading="lazy"
          class="img-shimmer w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          onload="this.classList.add('is-loaded')"
        />
      </div>
    ) : (
      <div
        class="aspect-[16/9] flex items-center justify-center"
        style={`background:linear-gradient(135deg, ${accentHex}38, ${accentHex}0d)`}
      >
        {post.category && (
          <span class="text-xs uppercase tracking-widest font-medium" style={`color:${accentHex}`}>
            {post.category}
          </span>
        )}
      </div>
    )}
    <div class="p-5 flex-1 flex flex-col">
      <div class="flex items-baseline gap-3 mb-2">
        <time class="text-xs text-ink-muted font-mono">{formatDateShort(post.date)}</time>
        {showCategory && post.category && (
          <span class={`text-[10px] uppercase tracking-widest text-${accent}`}>
            {post.category}
          </span>
        )}
      </div>
      <Title class="font-serif text-lg font-semibold text-ink leading-snug mb-2 group-hover:text-moss-dark">
        {post.title}
      </Title>
      {post.excerpt && (
        <p class="text-sm text-ink-muted leading-relaxed line-clamp-3 flex-1">
          {post.excerpt}
        </p>
      )}
      <div class="mt-3 flex items-center gap-3">
        <ReadingTimeBadge minutes={post.reading_time} size="sm" />
        {post.series && post.episode != null && <span class="text-xs text-ink-muted">{post.series} #{post.episode}</span>}
      </div>
    </div>
  </a>
)}
