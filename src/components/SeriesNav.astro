---
import type { Post } from "../lib/posts";

interface Props {
  series: string;
  prev: Post | null;
  next: Post | null;
}
const { series, prev, next } = Astro.props;
---

<nav class="mt-12 border-t border-paper-300 pt-6 grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
  {
    prev ? (
      <a href={`/posts/${prev.slug}/`} class="group block p-4 bg-paper-50 rounded-md border border-paper-200 hover:border-moss no-underline">
        <div class="text-[10px] uppercase tracking-widest text-ink-muted mb-1">← 前の話</div>
        <div class="font-serif text-moss-dark group-hover:text-ink line-clamp-2">{prev.title}</div>
      </a>
    ) : (
      <div />
    )
  }
  {
    next ? (
      <a href={`/posts/${next.slug}/`} class="group block p-4 bg-paper-50 rounded-md border border-paper-200 hover:border-moss no-underline text-right">
        <div class="text-[10px] uppercase tracking-widest text-ink-muted mb-1">次の話 →</div>
        <div class="font-serif text-moss-dark group-hover:text-ink line-clamp-2">{next.title}</div>
      </a>
    ) : (
      <div />
    )
  }
</nav>

<div class="mt-4 text-center">
  <a href={`/series/${encodeURIComponent(series)}/`} class="text-xs text-ink-muted no-underline hover:text-ink">
    📚 「{series}」の目次へ
  </a>
</div>
