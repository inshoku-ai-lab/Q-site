---
interface Props {
  minutes: number;
  size?: "sm" | "md";
}
const { minutes, size = "md" } = Astro.props;
const sizeClass = size === "sm" ? "text-[10px] px-2 py-0.5 gap-1" : "text-xs px-2.5 py-1 gap-1.5";
const iconSize = size === "sm" ? 10 : 12;
---

<span class={`inline-flex items-center ${sizeClass} rounded-full bg-earth/10 text-earth font-medium whitespace-nowrap`}>
  <svg width={iconSize} height={iconSize} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0">
    <circle cx="12" cy="12" r="9" />
    <path d="M12 7v5l3 3" />
  </svg>
  約{minutes}分
</span>
